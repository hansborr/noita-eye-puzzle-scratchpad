{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(git reset --hard:*)",
      "Bash(git reset --soft:*)",
      "Bash(git reset --mixed:*)",
      "Bash(git reset --keep:*)",
      "Bash(git reset HEAD~:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(git update-ref:*)",
      "Bash(git replace:*)",
      "Bash(git reflog expire:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --mirror:*)",
      "Bash(git push --delete:*)",
      "Bash(git push -d:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch -df:*)",
      "Bash(git branch -fd:*)",
      "Bash(git clean -f:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh release delete:*)",
      "Bash(gh secret set:*)"
    ]
  }
}
