[codespell]
skip = ./target,.git,Cargo.lock,./research/data/lang,./research/data/practice-puzzles,./research/gak-threads/candidates
# `research/data/lang` is skipped so public-domain calibration excerpts,
# especially Finnish source text, are not altered to satisfy an English
# spelling dictionary. `research/data/practice-puzzles` is skipped for the same
# reason: it holds external cipher *ciphertext* samples that must never be
# altered (transcription-integrity rule, AGENTS.md), so spell-checking them is
# categorically wrong (e.g. the ciphertext token `EMAC` in `five`).
# `research/gak-threads/candidates` is skipped on the same grounds: those are
# machine-written candidate-cleartext HYPOTHESIS records whose rendered
# cleartext (e.g. the base-6 grouping token `ALLL` in `solve-six`) is data that
# the candidate-logging / transcription-integrity directive forbids altering,
# so spell-checking it is categorically wrong.
# Domain words / abbreviations that are not typos (`implementors` is Rust
# rustdoc terminology; the hyphenated forms are deliberate doc style).
ignore-words-list = crate,ser,noita,nd,wont,Statics,substition,periodioc,implementors,pre-empt,re-declare,re-declared
