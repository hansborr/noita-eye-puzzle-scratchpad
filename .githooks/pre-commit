#!/usr/bin/env bash
# Pre-commit gate for noita-eye-puzzle. Install with `make setup`
# (sets core.hooksPath = .githooks). The Rust gate mirrors the correctness
# checks in .github/workflows/ci.yml; the release build and codespell/machete
# are left to CI to keep commits fast.
set -euo pipefail

guard_protected_branch() {
    if [[ "${ALLOW_COMMIT_ON_MAIN:-}" == "1" ]]; then
        return 0
    fi

    local branch
    if branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null)"; then
        case "$branch" in
            main | master)
                cat >&2 <<EOF
pre-commit: refusing to commit directly on $branch.
pre-commit: create a feature branch first, or use ALLOW_COMMIT_ON_MAIN=1 for an emergency override.
EOF
                exit 1
                ;;
        esac
    fi
}

source_relevant_path() {
    local path="$1"

    case "$path" in
        *.rs | Cargo.toml | Cargo.lock | */Cargo.toml | */Cargo.lock | .githooks/* | scripts/* | .github/workflows/* | research/data/* | tests/* | .shellcheckrc)
            return 0
            ;;
    esac

    [[ "$path" != */* && "$path" == *.toml ]]
}

source_relevant_unstaged_paths() {
    local path
    while IFS= read -r -d '' path; do
        if source_relevant_path "$path"; then
            printf '%s\0' "$path"
        fi
    done < <(git diff --name-only -z)
}

source_relevant_untracked_paths() {
    local path
    while IFS= read -r -d '' path; do
        if source_relevant_path "$path"; then
            printf '%s\0' "$path"
        fi
    done < <(git ls-files --others --exclude-standard -z)
}

guard_clean_source_worktree() {
    if [[ "${ALLOW_DIRTY_COMMIT:-}" == "1" ]]; then
        return 0
    fi

    # The Rust/shell gates run against the working tree, while git commits the
    # index. Source-relevant unstaged or untracked files would mean the gate
    # verified something other than the commit being created.
    local unstaged=()
    local untracked=()
    local path
    while IFS= read -r -d '' path; do
        unstaged+=("$path")
    done < <(source_relevant_unstaged_paths)
    while IFS= read -r -d '' path; do
        untracked+=("$path")
    done < <(source_relevant_untracked_paths)

    if (( ${#unstaged[@]} == 0 && ${#untracked[@]} == 0 )); then
        return 0
    fi

    {
        echo "pre-commit: source-relevant working tree changes are not staged."
        echo "pre-commit: stage or stash them first so verified == committed; git stash -k keeps staged changes."
        if (( ${#unstaged[@]} > 0 )); then
            echo "pre-commit: unstaged source-relevant paths:"
            printf '  %s\n' "${unstaged[@]}"
        fi
        if (( ${#untracked[@]} > 0 )); then
            echo "pre-commit: untracked source-relevant paths:"
            printf '  %s\n' "${untracked[@]}"
        fi
        echo "pre-commit: emergency override: ALLOW_DIRTY_COMMIT=1"
    } >&2
    exit 1
}

run() {
    printf '\033[1mpre-commit:\033[0m %s\n' "$1"
    shift
    "$@"
}

staged() {
    git diff --cached --name-only --diff-filter=ACM "$@"
}

guard_protected_branch
guard_clean_source_worktree

if [[ "${PRECOMMIT_GUARDS_ONLY:-}" == "1" ]]; then
    echo "pre-commit: guards OK"
    exit 0
fi

run "blob-size" ./scripts/check-blob-size.sh

# --- Rust gate: only when Rust-relevant files are staged ---
if staged | grep -qE '\.rs$|(^|/)Cargo\.(toml|lock)$|(^|/)(clippy|deny)\.toml$'; then
    run "rustfmt" cargo fmt --check
    run "clippy" cargo clippy --all-targets --all-features --locked -- -D warnings
    run "file-size" ./scripts/check-file-size.sh
    RUSTFLAGS="-D warnings" run "tests" cargo test --locked
    RUSTDOCFLAGS="-D warnings" run "rustdoc" cargo doc --no-deps --locked
    if command -v cargo-deny >/dev/null 2>&1; then
        run "cargo-deny" cargo deny check
    else
        echo "pre-commit: cargo-deny not installed — skipping (CI still enforces it)"
    fi
fi

# --- Shell gate: only when shell scripts are staged ---
shell_files=()
while IFS= read -r -d '' f; do
    shell_files+=("$f")
done < <(staged -z 2>/dev/null | grep -zE '\.(sh|bash)$|(^|/)\.githooks/' || true)

if [ "${#shell_files[@]}" -gt 0 ]; then
    if command -v shellcheck >/dev/null 2>&1; then
        run "shellcheck" shellcheck -x "${shell_files[@]}"
    else
        echo "pre-commit: shellcheck not installed — skipping (CI still enforces it)"
    fi
fi

echo "pre-commit: OK"
